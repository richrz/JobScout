# Core runtime
NODE_ENV="development"
NEXT_DISABLE_DEVTOOLS=1
NEXT_TELEMETRY_DISABLED=1

# Database (required)
DATABASE_URL="postgresql://user:pass@localhost:5432/jobsearch"

# Authentication (recommended)
NEXTAUTH_URL="http://localhost:3173"
NEXTAUTH_SECRET="replace_with_openssl_rand_base64_32"
SINGLE_USER_MODE="false"

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Jobs ingestion / scraping (required for real imports)
JSEARCH_API_KEY=""

# Maps (optional)
GOOGLE_MAPS_API_KEY=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# Cache (optional)
REDIS_URL="redis://localhost:6379"

# LLM providers (optional)
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
ANTHROPIC_BASE_URL=""
OPENROUTER_API_KEY=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
GOOGLE_API_KEY=""
OLLAMA_BASE_URL="http://localhost:11434/v1"

# Cloud Talent Solution (optional — enables semantic search, commute filters)
GOOGLE_CLOUD_PROJECT_ID=""
CTS_TENANT_ID="default"
GOOGLE_APPLICATION_CREDENTIALS=""  # Path to GCP service account JSON key

# Cron/API hardening (optional)
CRON_SECRET=""
