generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  profile       Profile?
  applications  Application[]
  config        Config?
  sessions      Session[]
  accounts      Account[]
  resumes       Resume[]
  workspaces    Workspace[]

  @@index([email])
}

model Profile {
  id             String           @id @default(cuid())
  userId         String           @unique
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactInfo    Json
  workHistory    Json[] // Legacy, to be migrated
  experiences    WorkExperience[]
  education      Json[] // Legacy, to be migrated
  educations     Education[]
  skills         String[]
  projects       Json[]
  certifications Json[]
  preferences    Json
  completeness   Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Job {
  id             String        @id @default(cuid())
  title          String
  company        String
  location       String
  latitude       Float?
  longitude      Float?
  description    String        @db.Text
  salary         String?
  postedAt       DateTime
  source         String
  sourceUrl      String        @unique
  ctsJobName     String?       // Cloud Talent Solution resource name (projects/.../jobs/...)
  cityMatch      String?
  distanceMiles  Float?
  compositeScore Float?
  createdAt      DateTime      @default(now())
  applications   Application[]
  workspaces     Workspace[]
  resumes        Resume[]

  @@index([postedAt, source])
  @@index([cityMatch, compositeScore])
  @@index([title, company])
  @@index([location])
  @@index([createdAt])
  @@index([ctsJobName])
}

model Application {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status        String    @default("discovered")
  resumePath    String?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  appliedAt     DateTime?
  statusHistory Json[]
  resumes       Resume[]
  workspace     Workspace?

  @@index([userId, status])
  @@index([jobId])
}

// --- V2 CRM Models ---

enum ApplicationStatus {
  INTERESTED
  APPLIED
  FOLLOW_UP
  DORMANT
  ARCHIVED
  PASSED
}

enum DocumentState {
  REFERENCE
  WORKING_DRAFT
  SAVED_VARIANT
  SUBMITTED_SNAPSHOT
}

model Workspace {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicationId String?           @unique
  application   Application?      @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  status        ApplicationStatus @default(INTERESTED)
  priority      String            @default("medium") // high, medium, low
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  artifacts Artifact[]
  notes     WarRoomNote[]
  resumes   Resume[]

  @@unique([userId, jobId]) // One workspace per job per user
  @@index([status])
}

model Artifact {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        String    // RESUME, COVER_LETTER, OTHER
  name        String
  storagePath String
  content     String?   @db.Text // Text content if applicable
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

model WarRoomNote {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content     String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model Config {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  searchParams Json
  llmConfig    Json
  dailyCaps    Json
  fileNaming   String   @default("YYYY-MM-DD - {company} - {role}.pdf")
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ConfigHistory {
  id           String   @id @default(cuid())
  configId     String
  userId       String
  searchParams Json
  llmConfig    Json
  dailyCaps    Json
  fileNaming   String
  version      Int
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model WorkExperience {
  id           String    @id @default(cuid())
  profileId    String
  profile      Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  position     String
  company      String
  location     String?
  startDate    DateTime
  endDate      DateTime?
  current      Boolean   @default(false)
  description  String    @db.Text
  technologies String[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([profileId])
}

model Education {
  id          String    @id @default(cuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  school      String
  degree      String
  field       String
  startDate   DateTime
  endDate     DateTime?
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([profileId])
}

model Resume {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workspaceId   String?
  workspace     Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  applicationId String?
  application   Application?   @relation(fields: [applicationId], references: [id])
  title         String
  documentState DocumentState  @default(WORKING_DRAFT)
  content       Json
  tailoringMode String         @default("strategic") // strict, strategic, visionary
  pdfSnapshot   String?
  atsScore      Float?
  feedback      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId, jobId])
  @@index([workspaceId, documentState])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}
