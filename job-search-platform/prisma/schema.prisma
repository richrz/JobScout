generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  profile       Profile?
  applications  Application[]
  config        Config?
  sessions      Session[]
  accounts      Account[]
  resumes       Resume[]
  workspaces    Workspace[]

  @@index([email])
}

model Profile {
  id             String           @id @default(cuid())
  userId         String           @unique
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactInfo    Json
  workHistory    Json[] // Legacy, to be migrated
  experiences    WorkExperience[]
  education      Json[] // Legacy, to be migrated
  educations     Education[]
  skills         String[]
  projects       Json[]
  certifications Json[]
  preferences    Json
  completeness   Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model Job {
  id             String        @id @default(cuid())
  title          String
  company        String
  location       String
  latitude       Float?
  longitude      Float?
  description    String        @db.Text
  salary         String?
  postedAt       DateTime
  source         String
  sourceUrl      String        @unique
  ctsJobName     String?       // Cloud Talent Solution resource name (projects/.../jobs/...)
  cityMatch      String?
  distanceMiles  Float?
  compositeScore Float?
  createdAt      DateTime      @default(now())

  // --- Pipeline provenance fields (P0 — additive, all nullable) ---
  // sourceType distinguishes pipeline origin: "api" | "scraped" | "manual"
  sourceType         String?
  // canonicalUrl is the unrolled terminal ATS URL (after redirect resolution).
  // Distinct from sourceUrl (aggregator link). Used as the cross-source dedup key.
  canonicalUrl       String?
  // fingerprint is SHA256(normalize(company + title + canonical_location)).
  // Used for near-duplicate blocking independent of URL.
  fingerprint        String?   @unique
  // lastExtractedAt is set by the scraper/ingestion worker at fetch time.
  // Used by the stale-overwrite trigger to reject delayed worker results.
  lastExtractedAt    DateTime?
  // recordConfidence tracks how reliable normalized fields are (0.0–1.0).
  // NULL means the record predates the normalization contract.
  recordConfidence   Float?
  // normalizationVersion stamps which contract version was applied.
  // NULL means the record predates versioned normalization.
  normalizationVersion String?

  // --- Structured extraction fields (P0 — additive, all nullable) ---
  // Replaces the opaque salary String with structured min/max for filter queries.
  salaryMin      Float?
  salaryMax      Float?
  salaryCurrency String?       @default("USD")
  // Normalized work mode — reliable enum-like string for filter queries.
  // Values: "remote" | "hybrid" | "onsite" | "unknown"
  workMode       String?
  // Normalized seniority — for filter queries.
  // Values: "entry" | "mid" | "senior" | "staff_plus" | "unknown"
  seniority      String?
  // Extracted skills tags array — for keyword matching and filter facets.
  skillsTags     String[]

  // --- P1: Company entity resolution (nullable FK — old rows stay NULL) ---
  companyId      String?
  companyEntity  Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  applications      Application[]
  workspaces        Workspace[]
  resumes           Resume[]
  observedListings  ObservedListing[]

  @@index([postedAt, source])
  @@index([cityMatch, compositeScore])
  @@index([title, company])
  @@index([location])
  @@index([createdAt])
  @@index([ctsJobName])
  // P0 indexes
  @@index([sourceType])
  @@index([canonicalUrl])
  @@index([workMode])
  @@index([seniority])
  @@index([lastExtractedAt])
  // P1 indexes
  @@index([companyId])
}

model Application {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status        String    @default("discovered")
  resumePath    String?
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  appliedAt     DateTime?
  statusHistory Json[]
  resumes       Resume[]
  workspace     Workspace?

  @@index([userId, status])
  @@index([jobId])
}

// --- V2 CRM Models ---

enum ApplicationStatus {
  INTERESTED
  APPLIED
  SCREENING
  INTERVIEW
  OFFER
  FOLLOW_UP
  DORMANT
  ARCHIVED
  PASSED
}

enum DocumentState {
  REFERENCE
  WORKING_DRAFT
  SAVED_VARIANT
  SUBMITTED_SNAPSHOT
}

model Workspace {
  id            String            @id @default(cuid())
  userId        String
  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  applicationId String?           @unique
  application   Application?      @relation(fields: [applicationId], references: [id], onDelete: SetNull)
  status        ApplicationStatus @default(INTERESTED)
  priority      String            @default("medium") // high, medium, low
  statusHistory Json              @default("[]")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  artifacts Artifact[]
  notes     WarRoomNote[]
  resumes   Resume[]

  @@unique([userId, jobId]) // One workspace per job per user
  @@index([status])
}

model Artifact {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type        String    // RESUME, COVER_LETTER, OTHER
  name        String
  storagePath String
  content     String?   @db.Text // Text content if applicable
  createdAt   DateTime  @default(now())

  @@index([workspaceId])
}

model WarRoomNote {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  content     String    @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId])
}

model Config {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  searchParams Json
  llmConfig    Json
  dailyCaps    Json
  fileNaming   String   @default("YYYY-MM-DD - {company} - {role}.pdf")
  version      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ConfigHistory {
  id           String   @id @default(cuid())
  configId     String
  userId       String
  searchParams Json
  llmConfig    Json
  dailyCaps    Json
  fileNaming   String
  version      Int
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
}

model WorkExperience {
  id           String    @id @default(cuid())
  profileId    String
  profile      Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  position     String
  company      String
  location     String?
  startDate    DateTime
  endDate      DateTime?
  current      Boolean   @default(false)
  description  String    @db.Text
  technologies String[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([profileId])
}

model Education {
  id          String    @id @default(cuid())
  profileId   String
  profile     Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  school      String
  degree      String
  field       String
  startDate   DateTime
  endDate     DateTime?
  description String?   @db.Text
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([profileId])
}

model Resume {
  id            String         @id @default(cuid())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId         String
  job           Job            @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workspaceId   String?
  workspace     Workspace?     @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  applicationId String?
  application   Application?   @relation(fields: [applicationId], references: [id])
  title         String
  documentState DocumentState  @default(WORKING_DRAFT)
  content       Json
  tailoringMode String         @default("strategic") // strict, strategic, visionary
  pdfSnapshot   String?
  atsScore      Float?
  feedback      Json?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([userId, jobId])
  @@index([workspaceId, documentState])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ── P1: Company — canonical employer entity ───────────────────────────────────
//
// Normalizes free-text company strings across sources.
// "Garmin Ltd.", "Garmin International", "Garmin" all resolve to one row.
// Job.companyId is a nullable FK — old rows keep NULL, new ingested rows
// are resolved on write via normalizeCompanyName() in the ingestion layer.
//
// ats_system: known ATS platform ("greenhouse" | "lever" | "workday" | "neogov"
//   | "icims" | "taleo" | "smartrecruiters" | "unknown"). Used to route
//   the ATS-type classifier so deterministic parsers run instead of LLM.

model Company {
  id             String   @id @default(cuid())
  canonicalName  String   @unique  // normalized lowercase slug for dedup
  displayName    String            // human-readable name shown in UI
  domain         String?           // primary web domain, e.g. "garmin.com"
  careerPageUrl  String?           // root ATS/careers URL
  atsSystem      String?           // "greenhouse"|"lever"|"workday"|"neogov"|"unknown"
  logoUrl        String?           // cached logo for UI
  linkedinUrl    String?
  employeeCount  Int?              // rough headcount bucket
  industry       String?           // e.g. "Technology", "Government"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  jobs Job[]

  @@index([domain])
  @@index([atsSystem])
}

// ── P1: ObservedListing — one row per raw source occurrence of a job ──────────
//
// Separates "where we saw it" from "what the canonical job is."
// When Garmin's posting appears on Greenhouse, JSearch, and a staffing agency:
//   → 3 ObservedListing rows (one per source)
//   → 1 Job row (canonical golden record)
//
// This table is the audit trail and the dedup input layer.
// raw_content stores the original scraped payload for re-extraction without
// re-fetching — important when the normalization contract version bumps.
//
// Lifecycle:
//   1. Scraper fetches raw HTML / JSON → writes ObservedListing (rawContent, extractedAt)
//   2. Normalization runs → writes/updates canonical Job, sets canonicalJobId
//   3. Dedup worker reconciles ObservedListings sharing the same fingerprint/canonicalUrl
//      and may point multiple listings to the same canonical Job
//
// onDelete: Cascade — if the canonical Job is deleted, its provenance is gone too.
// If we ever need to tombstone a job without losing provenance, switch to Restrict + soft-delete.

model ObservedListing {
  id              String    @id @default(cuid())
  // The canonical job this listing was resolved to (null until dedup runs)
  jobId           String?
  job             Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)

  // Source identity
  source          String                    // "jsearch" | "greenhouse" | "lever" | "company" | ...
  sourceUrl       String                    // original URL where listing was found
  canonicalUrl    String?                   // resolved ATS URL after redirect (if known)
  sourceType      String                    // "api" | "scraped" | "manual"

  // Extraction snapshot — the raw payload at fetch time
  rawContent      String?   @db.Text        // original HTML or JSON string
  extractedAt     DateTime                  // when the scraper fetched this

  // Normalization output — what was parsed from rawContent
  extractedTitle       String?
  extractedCompany     String?
  extractedLocation    String?
  extractedSalary      String?
  extractedPostedAt    DateTime?
  normalizationVersion String?              // contract version used to parse this listing
  normalizationError   String?             // non-null if extraction failed

  createdAt       DateTime  @default(now())

  @@index([jobId])
  @@index([source, sourceUrl])
  @@index([canonicalUrl])
  @@index([extractedAt])
  @@index([source, extractedAt])  // used by per-source health queries
}

// ── P1: DedupeDecision — audit log for dedup pipeline decisions ───────────────
//
// Every time two ObservedListings are evaluated for identity, the result is
// logged here regardless of outcome. This enables:
//   - Auditing merge decisions that turned out to be wrong
//   - Tuning thresholds (how often do gray-zone LLM calls agree with embeddings?)
//   - Replaying decisions when the pipeline logic changes
//
// method: "exact_url" | "fingerprint" | "embedding" | "llm"
// outcome: "same" | "different" | "uncertain"

model DedupeDecision {
  id                 String    @id @default(cuid())
  listingAId         String                    // first ObservedListing.id compared
  listingBId         String                    // second ObservedListing.id compared
  method             String                    // which tier made the call
  outcome            String                    // "same" | "different" | "uncertain"
  similarity         Float?                    // embedding cosine score if applicable
  mergedIntoJobId    String?                   // set when outcome="same", the canonical Job
  llmReasoning       String?   @db.Text        // LLM explanation if method="llm"
  createdAt          DateTime  @default(now())

  @@index([listingAId])
  @@index([listingBId])
  @@index([outcome, createdAt])
  @@index([mergedIntoJobId])
}
